{
  "name": "kal-ai",
  "version": "0.1.0",
  "private": true,
  "description": "KAL-AI: AI-driven game development engine",
  "bin": {
    "kal": "./apps/engine/dist/bin.js"
  },
  "scripts": {
    "setup": "pnpm install && pnpm run link:global",
    "link:global": "bash ./scripts/link-global.sh",
    "build": "bun run --filter='@kal-ai/*' build",
    "test": "bun run --filter='@kal-ai/*' test",
    "test:coverage": "bun run --filter='@kal-ai/*' test:coverage",
    "typecheck": "bun run --filter='@kal-ai/*' typecheck",
    "clean": "bun run --filter='@kal-ai/*' clean",
    "generate-docs": "bun scripts/generate-docs.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "postinstall": "pnpm --filter @kal-ai/engine build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
