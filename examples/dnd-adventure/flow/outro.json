        "config": {
          "value": "描述冒险者的结局。",
          "type": "string"
        }
      },
      {
        "id": "generate-text",
        "type": "GenerateText",
        "label": "生成结局叙事",
        "position": {
          "x": 908,
          "y": 132
        },
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "model": "",
          "temperature": 0.8,
          "maxTokens": 800,
          "historyKey": "history",
          "assistantPath": ""
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "输出结果",
        "position": {
          "x": 1356,
          "y": 132
        },
        "inputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
