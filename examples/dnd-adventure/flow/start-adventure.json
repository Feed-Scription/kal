{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "start-adventure",
    "description": "冒险开始旁白 — 根据角色背景个性化开场",
    "inputs": [],
    "outputs": [
      {
        "name": "result",
        "type": "string"
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": "prompt-build",
        "type": "PromptBuild",
        "label": "系统提示词",
        "inputs": [
          {
            "name": "data",
            "type": "object",
            "defaultValue": {}
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "estimatedTokens",
            "type": "number"
          }
        ],
        "config": {
          "fragments": [
            {
              "type": "base",
              "id": "instruction",
              "content": "你是一位经验丰富的 DND 地下城主。请用第二人称为冒险者写一段踏入鸦巢镇的开场叙事。\n\n场景要求：\n- 黄昏时分，冒险者踏过鸦巢镇吱呀作响的南门\n- 描写广场的乌鸦喷泉（已干涸）、告示板上墨迹未干的悬赏令（北矿失踪七人）\n- 醉鸦亭酒馆的暖光和嘈杂人声、锻魂坊的炉火和锤击声\n- 镇长府邸门前警惕的卫兵、远处晨光神殿的钟声\n- 北门外山路消失在暮色中，夜风带着不属于山林的阴冷\n\n个性化要求：\n- 根据冒险者的种族和职业，描写镇民对冒险者的第一反应（精灵会引来好奇目光，矮人会让铁匠多看两眼，法师的法杖会让人退避三舍）\n- 根据冒险者的背景故事，加入一句内心独白或回忆闪回，暗示冒险者来到此地的动机\n- 以「你的故事，从这里开始。」结尾\n\n风格：多层感官描写（视觉、听觉、嗅觉、触觉），250-400字。纯文本叙事，不要输出JSON。"
            },
            {
              "type": "field",
              "id": "name",
              "source": "state.playerName",
              "template": "冒险者名字: {{items}}"
            },
            {
              "type": "field",
              "id": "race",
              "source": "state.race",
              "template": "种族: {{items}}"
            },
            {
              "type": "field",
              "id": "class",
              "source": "state.class",
              "template": "职业: {{items}}"
            },
            {
              "type": "field",
              "id": "background",
              "source": "state.background",
              "template": "背景故事: {{items}}"
            }
          ],
          "format": "xml"
        }
      },
      {
        "id": "user-prompt",
        "type": "Constant",
        "label": "用户提示",
        "inputs": [],
        "outputs": [
          {
            "name": "value",
            "type": "string"
          }
        ],
        "config": {
          "value": "描写冒险者踏入鸦巢镇的开场。",
          "type": "string"
        }
      },
      {
        "id": "message",
        "type": "Message",
        "label": "组装消息",
        "inputs": [
          {
            "name": "system",
            "type": "string"
          },
          {
            "name": "user",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "config": {}
      },
      {
        "id": "generate-text",
        "type": "GenerateText",
        "label": "生成开场叙事",
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "model": "",
          "temperature": 0.85,
          "maxTokens": 800,
          "historyKey": "",
          "assistantPath": "",
          "timeout": 60000
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "输出结果",
        "inputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
      {
        "source": "prompt-build",
        "sourceHandle": "text",
        "target": "message",
        "targetHandle": "system"
      },
      {
        "source": "user-prompt",
        "sourceHandle": "value",
        "target": "message",
        "targetHandle": "user"
      },
      {
        "source": "message",
        "sourceHandle": "messages",
        "target": "generate-text",
        "targetHandle": "messages"
      },
      {
        "source": "generate-text",
        "sourceHandle": "text",
        "target": "signal-out",
        "targetHandle": "data"
      }
    ]
  }
}
