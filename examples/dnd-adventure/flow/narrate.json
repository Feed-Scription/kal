      },
      {
        "id": "message",
        "type": "Message",
        "label": "组装消息",
        "inputs": [
          {
            "name": "system",
            "type": "string"
          },
          {
            "name": "context",
            "type": "string"
          },
          {
            "name": "user",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "config": {
          "historyKey": "history",
          "summaryKey": "summary"
        }
      },
      {
        "id": "generate-text",
        "type": "GenerateText",
        "label": "LLM生成",
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]",
            "required": true
          },
          {
            "name": "historyUserMessage",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "model": "",
          "temperature": 0.85,
          "maxTokens": 4000,
          "timeout": 120000,
          "historyKey": "history",
          "historyPolicy": {
            "maxMessages": 12
          },
          "assistantPath": "narrative",
          "responseFormat": "json",
          "jsonSchema": {
            "type": "object",
            "properties": {
              "narrative": {
                "type": "string"
              },
              "stateChanges": {
                "type": "object",
                "properties": {
                  "health": {
                    "type": "number"
                  },
                  "gold": {
                    "type": "number"
                  },
                  "currentLocation": {
                    "type": "string"
                  },
                  "inventory": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "questStage": {
                    "type": "string",
                    "enum": [
                      "arrived",
                      "accepted",
                      "exploring",
                      "boss_found",
                      "completed"
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "narrative",
              "stateChanges"
            ],
            "additionalProperties": false
          }
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "输出响应",
        "inputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "response"
        }
      }
    ],
    "edges": [
