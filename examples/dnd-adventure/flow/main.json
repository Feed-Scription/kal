{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "main",
    "description": "DND 单人冒险 — 主编排流程",
    "inputs": [
      {
        "name": "playerInput",
        "type": "string",
        "required": true
      }
    ],
    "outputs": [
      {
        "name": "result",
        "type": "object"
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": "signal-in",
        "type": "SignalIn",
        "label": "玩家输入",
        "inputs": [],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "playerInput"
        }
      },
      {
        "id": "narrate",
        "type": "SubFlow",
        "label": "叙事子流程",
        "inputs": [
          {
            "name": "playerInput",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "response",
            "type": "string"
          }
        ],
        "config": {
          "ref": "narrate"
        }
      },
      {
        "id": "json-parse",
        "type": "JSONParse",
        "label": "解析JSON",
        "inputs": [
          {
            "name": "text",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          },
          {
            "name": "success",
            "type": "boolean"
          },
          {
            "name": "error",
            "type": "string"
          }
        ],
        "config": {
          "extractFromCodeBlock": true,
          "fixCommonErrors": true,
          "fixTruncated": true
        }
      },
      {
        "id": "apply-state",
        "type": "WriteState",
        "label": "回写状态",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "stateChanges",
          "allowedKeys": [
            "health",
            "gold",
            "currentLocation",
            "inventory",
            "questStage"
          ]
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "输出结果",
        "inputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
      {
        "source": "signal-in",
        "sourceHandle": "data",
        "target": "narrate",
        "targetHandle": "playerInput"
      },
      {
        "source": "narrate",
        "sourceHandle": "response",
        "target": "json-parse",
        "targetHandle": "text"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "apply-state",
        "targetHandle": "changes"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "signal-out",
        "targetHandle": "data"
      }
    ]
  }
}
