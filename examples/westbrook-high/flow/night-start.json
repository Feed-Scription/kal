{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "night-start",
    "description": "Start of night phase — generate social media posts, show daily summary",
    "inputs": [],
    "outputs": [
      {
        "name": "result",
        "type": "object"
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": "set-phase",
        "type": "ModifyState",
        "label": "Set phase to night",
        "inputs": [
          {
            "name": "key",
            "type": "string",
            "defaultValue": "phase"
          },
          {
            "name": "value",
            "type": "any",
            "defaultValue": "night"
          }
        ],
        "outputs": [
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {}
      },
      {
        "id": "prompt-build",
        "type": "PromptBuild",
        "label": "Night briefing + social media",
        "inputs": [
          {
            "name": "data",
            "type": "object",
            "defaultValue": {}
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          },
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "estimatedTokens",
            "type": "number"
          }
        ],
        "config": {
          "defaultRole": "system",
          "fragments": [
            {
              "type": "base",
              "id": "role",
              "content": "你是 Westbrook High 的叙事者。冷峻写实风格。\n\n现在是夜间阶段。玩家回到宿舍。生成：\n1. 回到宿舍的简短叙事（1-2句）\n2. 今日社交媒体动态（为2-4个NPC生成帖子）\n3. 匿名论坛热帖（1-2条）\n\nNPC社交媒体规则：\n- 帖子内容反映NPC当前mood和arc_stage\n- mood低的NPC可能发隐晦的、情绪化的帖子\n- mood高的NPC发正常的校园生活帖子\n- 某些帖子包含隐藏线索（用自然的方式嵌入）\n- 偶尔有帖子会标记为\"即将删除\"（敏感内容）\n- NPC的线上人格可能和线下不同（Tyler线上更真实）\n\n匿名论坛规则：\n- 混合真线索和红鲱鱼\n- 偶尔有NPC用匿名账号发帖（可通过语言风格识别）\n- 校园八卦增加世界感",
              "role": "system"
            },
            {
              "type": "field",
              "id": "day",
              "source": "state.day",
              "label": "当前天数"
            },
            {
              "type": "field",
              "id": "dayLog",
              "source": "state.dayLog",
              "label": "今日事件摘要"
            },
            {
              "type": "field",
              "id": "mood-lily",
              "source": "state.mood_lily",
              "label": "Lily情绪"
            },
            {
              "type": "field",
              "id": "mood-marcus",
              "source": "state.mood_marcus",
              "label": "Marcus情绪"
            },
            {
              "type": "field",
              "id": "mood-zoe",
              "source": "state.mood_zoe",
              "label": "Zoe情绪"
            },
            {
              "type": "field",
              "id": "mood-tyler",
              "source": "state.mood_tyler",
              "label": "Tyler情绪"
            },
            {
              "type": "field",
              "id": "arc-lily",
              "source": "state.arc_lily",
              "label": "Lily弧线"
            },
            {
              "type": "field",
              "id": "arc-marcus",
              "source": "state.arc_marcus",
              "label": "Marcus弧线"
            },
            {
              "type": "field",
              "id": "arc-tyler",
              "source": "state.arc_tyler",
              "label": "Tyler弧线"
            },
            {
              "type": "field",
              "id": "lineA",
              "source": "state.lineA_depth",
              "label": "Line A深度"
            },
            {
              "type": "field",
              "id": "lineB",
              "source": "state.lineB_depth",
              "label": "Line B深度"
            },
            {
              "type": "field",
              "id": "phoneUnlocked",
              "source": "state.phoneUnlocked_social",
              "label": "社交媒体已解锁"
            },
            {
              "type": "base",
              "id": "format",
              "content": "输出JSON：\n{\n  \"narrative\": \"回到宿舍的叙事（1-2句）\",\n  \"socialPosts\": [\n    {\n      \"author\": \"NPC名\",\n      \"handle\": \"@xxx\",\n      \"content\": \"帖子内容\",\n      \"comments\": [{ \"author\": \"评论者\", \"content\": \"评论\" }],\n      \"willDelete\": false,\n      \"hiddenClue\": false\n    }\n  ],\n  \"forumPosts\": [\n    {\n      \"title\": \"帖子标题\",\n      \"content\": \"帖子内容\",\n      \"isRealClue\": true或false,\n      \"isRedHerring\": true或false\n    }\n  ],\n  \"stateChanges\": {\n    \"todaySocialPosts\": \"社交帖子摘要\",\n    \"todayRumors\": \"论坛传闻摘要\"\n  }\n}",
              "role": "system"
            }
          ]
        }
      },
      {
        "id": "message",
        "type": "Message",
        "label": "Assemble",
        "inputs": [
          {
            "name": "system",
            "type": "string"
          },
          {
            "name": "user",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "config": {
          "historyKey": "history",
          "maxHistoryMessages": 4,
          "summaryKey": "summary"
        }
      },
      {
        "id": "generate",
        "type": "GenerateText",
        "label": "Generate night content",
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "responseFormat": "json",
          "historyKey": "history",
          "assistantPath": "narrative",
          "temperature": 0.9
        }
      },
      {
        "id": "json-parse",
        "type": "JSONParse",
        "label": "Parse",
        "inputs": [
          {
            "name": "text",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          },
          {
            "name": "success",
            "type": "boolean"
          },
          {
            "name": "error",
            "type": "string"
          }
        ],
        "config": {
          "extractFromCodeBlock": true,
          "fixCommonErrors": true,
          "fixTruncated": true
        }
      },
      {
        "id": "apply-state",
        "type": "ApplyState",
        "label": "Apply night state",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "stateChanges",
          "allowedKeys": [
            "todaySocialPosts",
            "todayRumors"
          ]
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "Output",
        "inputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
      {
        "source": "prompt-build",
        "sourceHandle": "text",
        "target": "message",
        "targetHandle": "system"
      },
      {
        "source": "message",
        "sourceHandle": "messages",
        "target": "generate",
        "targetHandle": "messages"
      },
      {
        "source": "generate",
        "sourceHandle": "text",
        "target": "json-parse",
        "targetHandle": "text"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "apply-state",
        "targetHandle": "changes"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "signal-out",
        "targetHandle": "data"
      }
    ]
  }
}
