      {
        "id": "message",
        "type": "Message",
        "label": "Assemble",
        "inputs": [
          {
            "name": "system",
            "type": "string"
          },
          {
            "name": "user",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "config": {
          "historyKey": "history",
          "maxHistoryMessages": 4,
          "summaryKey": "summary"
        }
      },
      {
        "id": "generate",
        "type": "GenerateText",
        "label": "Simulate world",
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "responseFormat": "json",
          "temperature": 0.8
        }
      },
      {
        "id": "json-parse",
        "type": "JSONParse",
        "label": "Parse",
        "inputs": [
          {
            "name": "text",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          },
          {
            "name": "success",
            "type": "boolean"
          },
          {
            "name": "error",
            "type": "string"
          }
        ],
        "config": {
          "extractFromCodeBlock": true,
          "fixCommonErrors": true,
          "fixTruncated": true
        }
      },
      {
        "id": "apply-state",
        "type": "ApplyState",
        "label": "Apply world changes",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "stateChanges",
          "allowedKeys": [
            "todayWorldEvents"
          ]
        }
      },
      {
        "id": "apply-npc",
        "type": "ApplyState",
        "label": "Apply NPC changes",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "npcChanges",
          "allowedKeys": [
            "mood_lily",
            "mood_marcus",
            "mood_coach",
            "mood_zoe",
            "mood_tyler",
            "mood_holloway",
            "arc_lily",
            "arc_marcus",
            "arc_coach",
            "arc_zoe",
            "arc_tyler",
            "arc_holloway"
          ]
        }
      },
      {
