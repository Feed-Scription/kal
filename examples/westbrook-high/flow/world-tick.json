              "label": "Zoe弧线"
            },
            {
              "type": "field",
              "id": "arc-tyler",
              "source": "state.arc_tyler",
              "label": "Tyler弧线"
            },
            {
              "type": "field",
              "id": "arc-coach",
              "source": "state.arc_coach",
              "label": "Coach弧线"
            },
            {
              "type": "field",
              "id": "arc-holloway",
              "source": "state.arc_holloway",
              "label": "Holloway弧线"
            },
            {
              "type": "field",
              "id": "fear-lily",
