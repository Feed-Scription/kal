{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "day-action",
    "description": "Process player's day action choice — explore, phone, infiltrate, eavesdrop, club, or end day",
    "inputs": [
      {
        "name": "actionChoice",
        "type": "string",
        "required": true
      }
    ],
    "outputs": [
      {
        "name": "result",
        "type": "object"
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": "signal-in",
        "type": "SignalIn",
        "label": "Action choice",
        "inputs": [],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "actionChoice"
        }
      },
      {
        "id": "narrate",
        "type": "SubFlow",
        "label": "Narrate action",
        "inputs": [
          {
            "name": "playerInput",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "response",
            "type": "string"
          }
        ],
        "config": {
          "ref": "narrate"
        }
      },
      {
        "id": "json-parse",
        "type": "JSONParse",
        "label": "Parse response",
        "inputs": [
          {
            "name": "text",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          },
          {
            "name": "success",
            "type": "boolean"
          },
          {
            "name": "error",
            "type": "string"
          }
        ],
        "config": {
          "extractFromCodeBlock": true,
          "fixCommonErrors": true,
          "fixTruncated": true
        }
      },
      {
        "id": "apply-state",
        "type": "ApplyState",
        "label": "Apply state changes",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "stateChanges",
          "allowedKeys": [
            "ap",
            "suspicion",
            "currentLocation",
            "lastEvent",
            "dayLog",
            "trust_lily",
            "trust_marcus",
            "trust_coach",
            "trust_zoe",
            "trust_tyler",
            "trust_holloway",
            "mood_lily",
            "mood_marcus",
            "mood_coach",
            "mood_zoe",
            "mood_tyler",
            "mood_holloway",
            "fear_lily",
            "fear_marcus",
            "fear_coach",
            "fear_zoe",
            "fear_tyler",
            "fear_holloway",
            "lineA_evidence",
            "lineB_evidence",
            "lineC_evidence",
            "faction_athletes",
            "faction_academics",
            "faction_arts",
            "faction_council",
            "pendingConfrontation",
            "phase"
          ]
        }
      },
      {
        "id": "apply-npc",
        "type": "ApplyState",
        "label": "Apply NPC changes",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "npcChanges",
          "allowedKeys": [
            "trust_lily",
            "trust_marcus",
            "trust_coach",
            "trust_zoe",
            "trust_tyler",
            "trust_holloway",
            "mood_lily",
            "mood_marcus",
            "mood_coach",
            "mood_zoe",
            "mood_tyler",
            "mood_holloway",
            "fear_lily",
            "fear_marcus",
            "fear_coach",
            "fear_zoe",
            "fear_tyler",
            "fear_holloway"
          ]
        }
      },
      {
        "id": "apply-cards",
        "type": "ApplyState",
        "label": "Append new cards",
        "inputs": [
          {
            "name": "changes",
            "type": "object",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "applied",
            "type": "array"
          },
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {
          "path": "newCards",
          "allowedKeys": ["topicCards", "evidenceCards"],
          "operations": {
            "topicCards": "appendMany",
            "evidenceCards": "appendMany"
          }
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "Output",
        "inputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "object"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
      {
        "source": "signal-in",
        "sourceHandle": "data",
        "target": "narrate",
        "targetHandle": "playerInput"
      },
      {
        "source": "narrate",
        "sourceHandle": "response",
        "target": "json-parse",
        "targetHandle": "text"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "apply-state",
        "targetHandle": "changes"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "apply-npc",
        "targetHandle": "changes"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "apply-cards",
        "targetHandle": "changes"
      },
      {
        "source": "json-parse",
        "sourceHandle": "data",
        "target": "signal-out",
        "targetHandle": "data"
      }
    ]
  }
}
