{
  "name": "showcase-signal-watch",
  "version": "0.1.0",
  "engine": {
    "logLevel": "warn",
    "maxConcurrentFlows": 1,
    "nodeTimeout": 60000,
    "runTimeout": 0
  },
  "llm": {
    "provider": "openai",
    "defaultModel": "Kimi-K2.5",
    "apiKey": "${OPENAI_API_KEY}",
    "baseUrl": "https://aiping.cn/api/v1",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 1000,
      "maxDelayMs": 10000,
      "backoffMultiplier": 2,
      "jitter": true
    },
    "cache": {
      "enabled": false
    }
  }
}
