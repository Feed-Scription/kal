{
  "schemaVersion": "1.0",
  "nodes": [
    {
      "id": "signal-in",
      "type": "SignalIn",
      "label": "玩家输入",
      "position": { "x": 100, "y": 100 },
      "inputs": [],
      "outputs": [
        { "name": "data", "type": "object" }
      ]
    },
    {
      "id": "read-state",
      "type": "ReadState",
      "label": "读取游戏状态",
      "position": { "x": 300, "y": 100 },
      "inputs": [
        { "name": "key", "type": "string", "defaultValue": "playerName" }
      ],
      "outputs": [
        { "name": "value", "type": "object" },
        { "name": "exists", "type": "boolean" }
      ]
    },
    {
      "id": "prompt-build",
      "type": "PromptBuild",
      "label": "构建 Prompt",
      "position": { "x": 500, "y": 100 },
      "inputs": [
        { "name": "data", "type": "object" }
      ],
      "outputs": [
        { "name": "text", "type": "string" },
        { "name": "estimatedTokens", "type": "number" }
      ],
      "config": {
        "fragments": [
          {
            "type": "base",
            "id": "system",
            "content": "You are a text RPG game master. Guide the player through an adventure.",
            "role": "system"
          },
          {
            "type": "field",
            "id": "player-info",
            "source": "playerName",
            "template": "Player name: {{items}}",
            "role": "user"
          }
        ]
      }
    },
    {
      "id": "message",
      "type": "Message",
      "label": "组装消息",
      "position": { "x": 700, "y": 100 },
      "inputs": [
        { "name": "system", "type": "string" },
        { "name": "user", "type": "string", "required": true }
      ],
      "outputs": [
        { "name": "messages", "type": "ChatMessage[]" }
      ],
      "config": {
        "format": "xml"
      }
    },
    {
      "id": "generate-text",
      "type": "GenerateText",
      "label": "生成回复",
      "position": { "x": 900, "y": 100 },
      "inputs": [
        { "name": "messages", "type": "ChatMessage[]", "required": true }
      ],
      "outputs": [
        { "name": "text", "type": "string" },
        { "name": "usage", "type": "object" }
      ],
      "config": {
        "model": "gpt-4",
        "temperature": 0.7,
        "maxTokens": 500
      }
    },
    {
      "id": "signal-out",
      "type": "SignalOut",
      "label": "输出结果",
      "position": { "x": 1100, "y": 100 },
      "inputs": [
        { "name": "data", "type": "object" }
      ],
      "outputs": [
        { "name": "data", "type": "object" }
      ]
    }
  ],
  "edges": [
    {
      "source": "signal-in",
      "sourceHandle": "data",
      "target": "read-state",
      "targetHandle": "key"
    },
    {
      "source": "read-state",
      "sourceHandle": "value",
      "target": "prompt-build",
      "targetHandle": "data"
    },
    {
      "source": "prompt-build",
      "sourceHandle": "text",
      "target": "message",
      "targetHandle": "user"
    },
    {
      "source": "message",
      "sourceHandle": "messages",
      "target": "generate-text",
      "targetHandle": "messages"
    },
    {
      "source": "generate-text",
      "sourceHandle": "text",
      "target": "signal-out",
      "targetHandle": "data"
    }
  ]
}
