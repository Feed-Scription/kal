{
  "name": "simple-chat",
  "version": "1.0.0",
  "engine": {
    "logLevel": "info",
    "maxConcurrentFlows": 1,
    "timeout": 30000
  },
  "llm": {
    "provider": "openai",
    "apiKey": "***REDACTED_QIANFAN_KEY***",
    "baseUrl": "https://aiping.cn/api/v1",
    "defaultModel": "GLM-5",
    "retry": {
      "maxRetries": 2,
      "initialDelayMs": 1000,
      "maxDelayMs": 10000,
      "backoffMultiplier": 2,
      "jitter": true
    },
    "cache": {
      "enabled": false
    }
  }
}
