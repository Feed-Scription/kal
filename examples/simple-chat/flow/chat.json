{
  "schemaVersion": "1.0",
  "nodes": [
    {
      "id": "signal-in",
      "type": "SignalIn",
      "label": "用户输入",
      "position": { "x": 100, "y": 100 },
      "inputs": [],
      "outputs": [
        { "name": "userMessage", "type": "string" },
        { "name": "history", "type": "ChatMessage[]" }
      ]
    },
    {
      "id": "message",
      "type": "Message",
      "label": "组装消息",
      "position": { "x": 300, "y": 100 },
      "inputs": [
        { "name": "system", "type": "string", "defaultValue": "你是一个友好的 AI 助手，请用中文回答。" },
        { "name": "user", "type": "string", "required": true },
        { "name": "history", "type": "ChatMessage[]" }
      ],
      "outputs": [
        { "name": "messages", "type": "ChatMessage[]" }
      ],
      "config": {}
    },
    {
      "id": "generate-text",
      "type": "GenerateText",
      "label": "生成回复",
      "position": { "x": 500, "y": 100 },
      "inputs": [
        { "name": "messages", "type": "ChatMessage[]", "required": true }
      ],
      "outputs": [
        { "name": "text", "type": "string" },
        { "name": "usage", "type": "object" }
      ],
      "config": {
        "temperature": 0.7,
        "maxTokens": 500
      }
    },
    {
      "id": "signal-out",
      "type": "SignalOut",
      "label": "输出结果",
      "position": { "x": 700, "y": 100 },
      "inputs": [
        { "name": "data", "type": "object" }
      ],
      "outputs": [
        { "name": "data", "type": "object" }
      ]
    }
  ],
  "edges": [
    {
      "source": "signal-in",
      "sourceHandle": "userMessage",
      "target": "message",
      "targetHandle": "user"
    },
    {
      "source": "signal-in",
      "sourceHandle": "history",
      "target": "message",
      "targetHandle": "history"
    },
    {
      "source": "message",
      "sourceHandle": "messages",
      "target": "generate-text",
      "targetHandle": "messages"
    },
    {
      "source": "generate-text",
      "sourceHandle": "text",
      "target": "signal-out",
      "targetHandle": "data"
    }
  ]
}
