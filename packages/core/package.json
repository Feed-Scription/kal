{
  "name": "@kal-ai/core",
  "version": "0.1.0",
  "description": "KAL-AI Core Engine — data-driven game runtime with built-in nodes, state management, and LLM integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Feed-Scription/kal.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Feed-Scription/kal#readme",
  "keywords": ["ai", "game-engine", "llm", "interactive-fiction", "state-machine", "flow", "dnd"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "esbuild": "^0.27.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
