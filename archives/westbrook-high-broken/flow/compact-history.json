{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "compact-history",
    "description": "Compress conversation history into summary to manage context window",
    "inputs": [],
    "outputs": [
      {
        "name": "result",
        "type": "string"
      }
    ]
  },
  "data": {
    "nodes": [
      {
        "id": "read-state",
        "type": "ReadState",
        "label": "Read history",
        "position": {
          "x": -550,
          "y": -22
        },
        "inputs": [
          {
            "name": "key",
            "type": "string",
            "required": true
          }
        ],
        "outputs": [
          {
            "name": "history",
            "type": "array"
          },
          {
            "name": "summary",
            "type": "string"
          },
          {
            "name": "all",
            "type": "object"
          }
        ],
        "config": {
          "keys": [
            "history",
            "summary"
          ]
        }
      },
      {
        "id": "prompt-build",
        "type": "PromptBuild",
        "label": "Compaction prompt",
        "position": {
          "x": -42,
          "y": 6
        },
        "inputs": [
          {
            "name": "data",
            "type": "object",
            "defaultValue": {}
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          },
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "estimatedTokens",
            "type": "number"
          }
        ],
        "config": {
          "defaultRole": "system",
          "fragments": [
            {
              "type": "base",
              "id": "role",
              "content": "你是一个叙事压缩器。将游戏历史对话压缩为简洁的摘要。\n\n规则：\n- 保留所有关键决策和转折点\n- 保留NPC关系变化的关键时刻\n- 保留调查线索的重要发现\n- 删除日常闲聊和重复信息\n- 用第三人称简述\n- 摘要不超过300字\n\n如果已有旧摘要，将新信息整合进去，保持总长度不超过400字。\n\n输出纯文本摘要，不需要JSON格式。",
              "role": "system"
            },
            {
              "type": "field",
              "id": "old-summary",
              "source": "state.summary",
              "label": "现有摘要"
            },
            {
              "type": "field",
              "id": "history",
              "source": "state.history",
              "label": "待压缩的历史"
            },
            {
              "type": "field",
              "id": "keyDecisions",
              "source": "state.keyDecisions",
              "label": "关键决策（必须保留）"
            }
          ]
        }
      },
      {
        "id": "message",
        "type": "Message",
        "label": "Assemble",
        "position": {
          "x": 400,
          "y": 0
        },
        "inputs": [
          {
            "name": "system",
            "type": "ChatMessage[]"
          },
          {
            "name": "user",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "config": {
          "system": "",
          "user": "",
          "format": "xml",
          "historyKey": "history",
          "maxHistoryMessages": 0
        }
      },
      {
        "id": "generate",
        "type": "GenerateText",
        "label": "Generate summary",
        "position": {
          "x": 600,
          "y": 0
        },
        "inputs": [
          {
            "name": "messages",
            "type": "ChatMessage[]"
          }
        ],
        "outputs": [
          {
            "name": "text",
            "type": "string"
          },
          {
            "name": "usage",
            "type": "object"
          }
        ],
        "config": {
          "model": "",
          "temperature": 0.3,
          "maxTokens": 2000,
          "historyKey": "history",
          "assistantPath": ""
        }
      },
      {
        "id": "write-summary",
        "type": "ModifyState",
        "label": "Write summary",
        "position": {
          "x": 800,
          "y": -60
        },
        "inputs": [
          {
            "name": "key",
            "type": "string",
            "defaultValue": "summary"
          },
          {
            "name": "value",
            "type": "any"
          }
        ],
        "outputs": [
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {}
      },
      {
        "id": "clear-history",
        "type": "ModifyState",
        "label": "Clear history",
        "position": {
          "x": 800,
          "y": 60
        },
        "inputs": [
          {
            "name": "key",
            "type": "string",
            "defaultValue": "history"
          },
          {
            "name": "value",
            "type": "any",
            "defaultValue": []
          }
        ],
        "outputs": [
          {
            "name": "success",
            "type": "boolean"
          }
        ],
        "config": {}
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "Output",
        "position": {
          "x": 1000,
          "y": 0
        },
        "inputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "outputs": [
          {
            "name": "data",
            "type": "string"
          }
        ],
        "config": {
          "channel": "result"
        }
      }
    ],
    "edges": [
      {
        "source": "prompt-build",
        "sourceHandle": "messages",
        "target": "message",
        "targetHandle": "system"
      },
      {
        "source": "message",
        "sourceHandle": "messages",
        "target": "generate",
        "targetHandle": "messages"
      },
      {
        "source": "generate",
        "sourceHandle": "text",
        "target": "write-summary",
        "targetHandle": "value"
      },
      {
        "source": "generate",
        "sourceHandle": "text",
        "target": "signal-out",
        "targetHandle": "data"
      }
    ]
  }
}