{
  "meta": {
    "schemaVersion": "1.0.0",
    "name": "day-start",
    "description": "Start of a new day — reset AP, determine if key day, generate morning briefing",
    "inputs": [],
    "outputs": [{ "name": "result", "type": "object" }]
  },
  "data": {
    "nodes": [
      {
        "id": "read-state",
        "type": "ReadState",
        "label": "Read day info",
        "position": { "x": 0, "y": 0 },
        "inputs": [],
        "outputs": [
          { "name": "day", "type": "number" },
          { "name": "suspicion", "type": "number" },
          { "name": "all", "type": "object" }
        ],
        "config": { "keys": ["day", "suspicion", "lineA_depth", "lineB_depth", "lineC_depth"] }
      },
      {
        "id": "set-ap",
        "type": "ModifyState",
        "label": "Reset AP to 3",
        "position": { "x": 200, "y": -80 },
        "inputs": [
          { "name": "key", "type": "string", "defaultValue": "ap" },
          { "name": "value", "type": "any", "defaultValue": 3 }
        ],
        "outputs": [{ "name": "success", "type": "boolean" }],
        "config": {}
      },
      {
        "id": "set-phase",
        "type": "ModifyState",
        "label": "Set phase to day",
        "position": { "x": 200, "y": 0 },
        "inputs": [
          { "name": "key", "type": "string", "defaultValue": "phase" },
          { "name": "value", "type": "any", "defaultValue": "day" }
        ],
        "outputs": [{ "name": "success", "type": "boolean" }],
        "config": {}
      },
      {
        "id": "set-daylog",
        "type": "ModifyState",
        "label": "Clear day log",
        "position": { "x": 200, "y": 80 },
        "inputs": [
          { "name": "key", "type": "string", "defaultValue": "dayLog" },
          { "name": "value", "type": "any", "defaultValue": "" }
        ],
        "outputs": [{ "name": "success", "type": "boolean" }],
        "config": {}
      },
      {
        "id": "prompt-build",
        "type": "PromptBuild",
        "label": "Morning briefing prompt",
        "position": { "x": 400, "y": 0 },
        "inputs": [{ "name": "data", "type": "object", "defaultValue": {} }],
        "outputs": [
          { "name": "messages", "type": "ChatMessage[]" },
          { "name": "text", "type": "string" },
          { "name": "estimatedTokens", "type": "number" }
        ],
        "config": {
          "defaultRole": "system",
          "fragments": [
            {
              "type": "base", "id": "role",
              "content": "你是 Westbrook High 的叙事者。冷峻写实风格。绝不用感叹号。\n\n生成新一天的晨间简报。包含：\n1. 日期和天气（简短）\n2. 今天的校园氛围（1句话，反映当前调查进度和怀疑值）\n3. 如果有未读的社交媒体通知，提及\n4. 如果是关键日，暗示今天会有不寻常的事\n\n输出JSON格式：\n{\n  \"narrative\": \"晨间叙事（3-5句话）\",\n  \"stateChanges\": {\n    \"isKeyDay\": true或false,\n    \"suspicion\": 当前怀疑值（每天自然衰减2，最低0）\n  }\n}\n\n关键日判定规则：\n- Day 1, 5, 8, 12, 15, 18, 20, 22-25, 28, 32-34, 35, 36 是固定关键日\n- 如果任一NPC弧线刚到达新阶段，也是关键日\n- 其他日子为普通日",
              "role": "system"
            },
            {
              "type": "field", "id": "day",
              "source": "state.day", "label": "当前天数"
            },
            {
              "type": "field", "id": "suspicion",
              "source": "state.suspicion", "label": "怀疑值"
            },
            {
              "type": "field", "id": "lineA",
              "source": "state.lineA_depth", "label": "Line A深度"
            },
            {
              "type": "field", "id": "lineB",
              "source": "state.lineB_depth", "label": "Line B深度"
            },
            {
              "type": "field", "id": "lineC",
              "source": "state.lineC_depth", "label": "Line C深度"
            },
            {
              "type": "field", "id": "lastEvent",
              "source": "state.lastEvent", "label": "昨日关键事件"
            },
            {
              "type": "field", "id": "gameStage",
              "source": "state.gameStage", "label": "游戏阶段"
            }
          ]
        }
      },
      {
        "id": "message",
        "type": "Message",
        "label": "Assemble",
        "position": { "x": 600, "y": 0 },
        "inputs": [
          { "name": "system", "type": "ChatMessage[]" },
          { "name": "user", "type": "string" }
        ],
        "outputs": [{ "name": "messages", "type": "ChatMessage[]" }],
        "config": { "historyKey": "history", "maxHistoryMessages": 4, "summaryKey": "summary" }
      },
      {
        "id": "generate",
        "type": "GenerateText",
        "label": "Generate briefing",
        "position": { "x": 800, "y": 0 },
        "inputs": [{ "name": "messages", "type": "ChatMessage[]" }],
        "outputs": [
          { "name": "text", "type": "string" },
          { "name": "usage", "type": "object" }
        ],
        "config": {
          "responseFormat": "json",
          "historyKey": "history",
          "assistantPath": "narrative"
        }
      },
      {
        "id": "json-parse",
        "type": "JSONParse",
        "label": "Parse response",
        "position": { "x": 1000, "y": 0 },
        "inputs": [{ "name": "text", "type": "string", "required": true }],
        "outputs": [
          { "name": "data", "type": "object" },
          { "name": "success", "type": "boolean" },
          { "name": "error", "type": "string" }
        ],
        "config": { "extractFromCodeBlock": true, "fixCommonErrors": true, "fixTruncated": true }
      },
      {
        "id": "apply-state",
        "type": "ApplyState",
        "label": "Apply changes",
        "position": { "x": 1200, "y": 80 },
        "inputs": [{ "name": "changes", "type": "object", "required": true }],
        "outputs": [
          { "name": "applied", "type": "array" },
          { "name": "success", "type": "boolean" }
        ],
        "config": {
          "path": "stateChanges",
          "allowedKeys": ["isKeyDay", "suspicion", "gameStage"]
        }
      },
      {
        "id": "signal-out",
        "type": "SignalOut",
        "label": "Output",
        "position": { "x": 1200, "y": -80 },
        "inputs": [{ "name": "data", "type": "object" }],
        "outputs": [{ "name": "data", "type": "object" }],
        "config": { "channel": "result" }
      }
    ],
    "edges": [
      { "source": "prompt-build", "sourceHandle": "messages", "target": "message", "targetHandle": "system" },
      { "source": "message", "sourceHandle": "messages", "target": "generate", "targetHandle": "messages" },
      { "source": "generate", "sourceHandle": "text", "target": "json-parse", "targetHandle": "text" },
      { "source": "json-parse", "sourceHandle": "data", "target": "apply-state", "targetHandle": "changes" },
      { "source": "json-parse", "sourceHandle": "data", "target": "signal-out", "targetHandle": "data" }
    ]
  }
}